datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model School {
  id               String              @id @default(uuid())
  name             String
  code             String              @unique
  email            String?
  phone            String?
  address          String?
  isActive         Boolean             @default(true)
  creditBalance    Int                 @default(0)
  createdAt        DateTime            @default(now())
  lecturers        Lecturer[]
  students         Student[]
  departments      Department[]
  courses          Course[]
  examPins         ExamPin[]
  creditTransactions CreditTransaction[]
}

model CreditTransaction {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  amount      Int
  type        String
  description String
  createdAt   DateTime @default(now())
}

model SuperAdmin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Lecturer {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  avatarData    String?
  departments   String         @default("[]")
  isAdmin       Boolean        @default(false)
  schoolId      String
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  courses       Course[]
  bankQuestions BankQuestion[]
}

model Student {
  id                    String                 @id @default(uuid())
  fullName              String
  email                 String?
  regNumber             String
  passwordHash          String?
  mustChangePassword    Boolean                @default(false)
  department            String                 @default("Computer Science")
  additionalDepartments String                 @default("[]")
  year                  String                 @default("Year 1")
  securityQuestion      String                 @default("What is your favorite academic course?")
  securityAnswer        String                 @default("Computer Science")
  avatarData            String?
  schoolId              String
  school                School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  attempts              StudentAttempt[]
  examSubmissions       ExamSubmission[]
  assignmentSubmissions AssignmentSubmission[]

  @@unique([schoolId, regNumber])
}

model Department {
  id        String   @id @default(uuid())
  name      String
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  courses   Course[]

  @@unique([schoolId, name])
}

model Course {
  id           String        @id @default(uuid())
  code         String
  title        String
  lecturerId   String
  lecturer     Lecturer      @relation(fields: [lecturerId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  targetYear   String?
  schoolId     String
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  notes        LectureNote[]
  quizzes      Quiz[]
  exams        Exam[]
  assignments  Assignment[]

  @@unique([schoolId, code])
}

model Exam {
  id                     String           @id @default(uuid())
  title                  String
  courseId               String
  course                 Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questionsText          String
  questionsStructureJson String?
  answerKeyText          String?
  answerKeyJson          String?
  marksText              String?
  isOpen                 Boolean          @default(true)
  availableFrom          DateTime?
  availableUntil         DateTime?
  createdAt              DateTime         @default(now())
  submissions            ExamSubmission[]
  pins                   ExamPin[]
}

model ExamSubmission {
  id          String   @id @default(uuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answersText String
  score       Float?
  totalMarks  Float?
  feedback    String?
  isGraded    Boolean  @default(false)
  submittedAt DateTime @default(now())

  @@unique([examId, studentId])
}

model LectureNote {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Quiz {
  id              String           @id @default(uuid())
  title           String
  durationMinutes Int
  availableFrom   DateTime?
  availableUntil  DateTime?
  courseId        String
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions       Question[]
  attempts        StudentAttempt[]
}

model Question {
  id            String @id @default(uuid())
  quizId        String
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text          String
  optionsJson   String
  correctOption String
}

model StudentAttempt {
  id          String    @id @default(uuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  isCompleted Boolean   @default(false)
  score       Float?
  answersJson String?
  violations  Int       @default(0)
}

model Assignment {
  id                     String                 @id @default(uuid())
  title                  String
  courseId               String
  course                 Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  description            String?
  questionsText          String
  questionsStructureJson String?
  answerKeyText          String?
  answerKeyJson          String?
  marksText              String?
  dueDate                DateTime?
  isOpen                 Boolean                @default(true)
  createdAt              DateTime               @default(now())
  submissions            AssignmentSubmission[]
}

model AssignmentSubmission {
  id             String     @id @default(uuid())
  assignmentId   String
  assignment     Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answersText    String
  attachmentName String?
  attachmentData String?
  score          Float?
  totalMarks     Float?
  feedback       String?
  isGraded       Boolean    @default(false)
  submittedAt    DateTime   @default(now())

  @@unique([assignmentId, studentId])
}

model ExamPin {
  id        String    @id @default(uuid())
  pin       String    @unique
  examId    String
  exam      Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  label     String?
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model BankQuestion {
  id            String   @id @default(uuid())
  lecturerId    String
  lecturer      Lecturer @relation(fields: [lecturerId], references: [id], onDelete: Cascade)
  text          String
  optionsJson   String
  correctOption String
  topic         String?
  createdAt     DateTime @default(now())
}
